# =============================================================================
# .env.example — Variables docker-compose
# =============================================================================
# Copier ce fichier en .env et adapter à votre déploiement :
#   cp .env.example .env
# Ne JAMAIS committer le .env réel (déjà dans .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# URLs publiques (CORS backend)
# Remplacer <host> par l'IP ou le nom de domaine de votre serveur.
#   Ex. en développement local : PUBLIC_URL=http://192.0.2.10:3000
# En production avec reverse-proxy + TLS :
#   PUBLIC_URL=https://repo.example.com
# -----------------------------------------------------------------------------
PUBLIC_URL=http://<host>:3000

# -----------------------------------------------------------------------------
# REACT_APP_* — utilisées uniquement si vous compilez le frontend depuis les
# sources (docker-compose.build.yml). Les images pré-construites
# ghcr.io/getautoflow/repod-ce/frontend utilisent des chemins relatifs
# (/api/...) proxifiés par nginx — aucune configuration requise.
# -----------------------------------------------------------------------------
REACT_APP_API_URL=
# Ex. REACT_APP_REPO_URL=http://192.0.2.10:80
REACT_APP_REPO_URL=http://<host>:80

# -----------------------------------------------------------------------------
# Version des images Docker (ghcr.io/getautoflow/repod-ce/*)
#   latest        → dernier build de la branche main
#   v1.2.3        → version taguée
# -----------------------------------------------------------------------------
REPOD_VERSION=latest

# -----------------------------------------------------------------------------
# Binding des ports (reverse proxy)
#
# Mode direct (dev) — défaut si non défini :
#   BIND_HOST=0.0.0.0   → ports accessibles depuis l'extérieur
#
# Mode derrière Traefik / nginx / Caddy :
#   BIND_HOST=127.0.0.1 → ports accessibles uniquement depuis le host,
#                         le reverse proxy achemine le trafic via le réseau Docker
#
# Ports exposés (modifier uniquement si conflit) :
# -----------------------------------------------------------------------------
BIND_HOST=0.0.0.0
FRONTEND_PORT=3000
BACKEND_PORT=8000
APT_PORT=80

# -----------------------------------------------------------------------------
# Mode TLS (docker-compose.tls.yml)
#
#   bash scripts/gen-selfsigned-certs.sh [IP_OU_DOMAINE]
#   docker compose -f docker-compose.yaml -f docker-compose.tls.yml up -d
#
# En mode TLS, apt-repo bascule sur APT_TLS_PORT (le port 80 est repris par le
# reverse proxy nginx-proxy pour la redirection HTTP → HTTPS).
# Mettre à jour les sources.list clients en conséquence :
#   deb [trusted=yes] http://<host>:8085/repos/dists/<codename> <codename> main
# -----------------------------------------------------------------------------
APT_TLS_PORT=8085

# -----------------------------------------------------------------------------
# Webhook secret — DOIT être identique à WEBHOOK_SECRET dans backend.env
# Générer avec : openssl rand -hex 32
# -----------------------------------------------------------------------------
WEBHOOK_SECRET=change-me
