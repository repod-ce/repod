# Nginx minimaliste pour servir les dépôts RPM (createrepo_c)
# Pas d'init-repo.sh — les arborescences {distrib}/{arch}/ sont gérées par le backend
FROM nginx:alpine

RUN rm -f /etc/nginx/conf.d/default.conf
COPY nginx/rpm.conf /etc/nginx/conf.d/repo.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
