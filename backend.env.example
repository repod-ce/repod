# =============================================================================
# backend.env.example — Secrets et configuration du backend FastAPI (env_file)
# =============================================================================
# Copier ce fichier en backend.env et adapter :
#   cp backend.env.example backend.env
# Ne JAMAIS committer le backend.env réel (déjà dans .gitignore).
#
# IMPORTANT : Docker Compose effectue une substitution de variables dans les
# fichiers env_file. Les `$` littéraux (ex : hash bcrypt) doivent être
# échappés en `$$`.
#
# À QUOI SERT CE FICHIER, PAR RAPPORT À .env.example :
#   - .env        → lu par `docker compose` lui-même (substitution ${VAR} DANS
#                    docker-compose.yaml : mots de passe DB, ports, tag d'image…)
#                    et ré-injecté tel quel dans le conteneur backend via
#                    `env_file: [.env]`.
#   - backend.env → lu UNIQUEMENT via `env_file: backend.env` du conteneur
#                    backend. Rien ici n'est jamais interprété par
#                    docker-compose.yaml lui-même.
#   Les deux fichiers sont chargés dans le conteneur backend, dans cet ordre :
#   `env_file: [backend.env, .env]` — en Docker Compose, en cas de clé
#   présente dans les deux, LE DERNIER FICHIER DE LA LISTE GAGNE. `.env` est
#   chargé après `backend.env` : une variable définie dans les DEUX fichiers
#   prend donc la valeur de `.env`, silencieusement. Ce fichier ne redéclare
#   donc jamais une variable déjà définie dans .env.example — voir l'encadré
#   ci-dessous pour la liste et la raison.
# =============================================================================

# -----------------------------------------------------------------------------
# ⚠ VARIABLES QUI N'ONT AUCUN EFFET ICI — définies ailleurs
#
# Ces variables ne doivent PAS être décommentées/modifiées dans backend.env :
# elles sont redéfinies plus loin dans la chaîne et backend.env perdrait
# silencieusement (aucune erreur, aucun log).
#
# 1) DATABASE_URL, JWT_SECRET_KEY, CORS_ORIGINS
#    Le service `backend` de docker-compose.yaml redéfinit ces trois clés
#    dans son bloc `environment:`, qui a toujours priorité sur `env_file:`
#    en Docker Compose. → définir POSTGRES_PASSWORD, JWT_SECRET_KEY,
#    CORS_ORIGINS dans **.env** à la place (voir .env.example). DATABASE_URL
#    n'est pas surchargeable séparément : il est reconstruit à partir de
#    POSTGRES_PASSWORD pour rester synchronisé avec le service `db`.
#
# 2) Chemins internes (POOL_DIR, MANIFEST_DIR, STAGING_INCOMING,
#    STAGING_QUARANTINE, AUDIT_DIR, INDEX_PATH, ADD_DEB_SCRIPT,
#    ADD_RPM_SCRIPT, IMPORTS_DIR, CLAMAV_DB_DIR, SETTINGS_PATH,
#    GRYPE_DB_CACHE_DIR, SECURITY_CACHE_DIR, NGINX_LOGS_DIR, GNUPG_HOME,
#    REPREPRO_BASE, DISTS_DIR, CONF_DIR, REPO_BASE, APK_REPO_BASE,
#    TRUSTED_PROXIES)
#    Tous fixés dans le bloc `environment:` de docker-compose.yaml, couplés
#    un-à-un aux volumes qui y sont déclarés. Ne les modifiez que dans
#    docker-compose.yaml lui-même, en cohérence avec les volumes
#    correspondants.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# JWT — Durée de vie des tokens (minutes)
# -----------------------------------------------------------------------------
JWT_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# Chiffrement des secrets de settings.json (SMTP/LDAP password, client_secret OIDC)
# Clé dédiée, indépendante de JWT_SECRET_KEY : une rotation de JWT_SECRET_KEY
# ne casse pas le déchiffrement de ces secrets. Si absente, JWT_SECRET_KEY est
# utilisé comme repli (déconseillé).
#   Générer avec : openssl rand -hex 32
# -----------------------------------------------------------------------------
SETTINGS_ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_RANDOM_64_HEX_STRING

# -----------------------------------------------------------------------------
# Licence — clé vendeur (Enterprise on-premise)
#
# Secret utilisé pour signer/vérifier les clés de licence Enterprise. Sans une
# valeur unique, n'importe qui ayant accès au code source (public) peut forger
# une licence Enterprise valide.
#
# OBLIGATOIRE en production (ENV=production, fixé par docker-compose.yaml) :
# le backend refuse de démarrer si cette variable est absente ou conserve sa
# valeur par défaut publiée dans le code source (échec immédiat, pas un
# avertissement). En développement (ENV=development), un avertissement est
# journalisé mais le démarrage n'est pas bloqué.
#   Générer avec : openssl rand -hex 32
# -----------------------------------------------------------------------------
REPOD_LICENSE_VENDOR_KEY=CHANGE_ME_GENERATE_A_RANDOM_64_HEX_STRING

# -----------------------------------------------------------------------------
# Compte administrateur initial
#
# Par défaut (variables ci-dessous absentes/vides), AUCUN compte n'est créé
# au démarrage : utilisez le wizard de première installation
# (GET/POST /api/v1/setup) pour créer le premier admin via l'interface web.
#
# Pour pré-provisionner un admin sans passer par le wizard (ex. déploiement
# automatisé), décommentez et renseignez les deux variables suivantes :
#   ADMIN_USERNAME=admin
#   ADMIN_PASSWORD_HASH=<hash bcrypt>
# Générer le hash avec :
#   python3 -c "from passlib.hash import bcrypt; print(bcrypt.hash('votre_mot_de_passe'))"
# Remplacer ensuite chaque `$` par `$$` dans la valeur (échappement env_file).
# -----------------------------------------------------------------------------
#ADMIN_USERNAME=admin
#ADMIN_PASSWORD_HASH=

# Protège POST /api/v1/setup pendant la fenêtre entre le démarrage du
# conteneur et la création du premier admin (course possible si le réseau
# du backend est accessible avant que le wizard soit complété).
# Si défini, le wizard exige le header `X-Setup-Token: <valeur>`.
#   Exemple : openssl rand -hex 32
#SETUP_TOKEN=

# -----------------------------------------------------------------------------
# Authentification — rate limiting et verrouillage de compte
# -----------------------------------------------------------------------------
# Requêtes/minute par IP sur les endpoints d'authentification (défaut : 10)
AUTH_RATELIMIT_PER_MINUTE=10

# Verrouillage de compte après N échecs de connexion consécutifs (défaut : 5),
# pendant M minutes (défaut : 15). Indépendant du rate limiting par IP
# ci-dessus (persistant par compte, pas juste par IP).
#LOGIN_MAX_ATTEMPTS=5
#LOGIN_LOCKOUT_MINUTES=15

# -----------------------------------------------------------------------------
# SSH — Téléchargement d'un paquet + dépendances depuis Internet (optionnel)
#
# Fonctionnalité optionnelle (bouton "Télécharger depuis Internet" sur la page
# Paquets) : le backend se connecte en SSH à la machine hôte Docker (PAS un
# conteneur) pour y exécuter download-package-dep.sh, qui récupère le paquet
# via apt et le copie dans le dépôt.
#
# SSH_HOST : IP/nom d'hôte de la machine hôte Docker, joignable depuis le
#            conteneur backend (ex. l'IP de l'hôte sur le réseau Docker bridge,
#            souvent 172.17.0.1, ou l'IP LAN de la machine).
# SSH_USER : utilisateur sur cette machine hôte, disposant de
#            ~/repodata/download-package-dep.sh et autorisant la connexion
#            via la clé SSH_KEY_PATH (./backend/ssh/id_ed25519 par défaut).
#
# Laisser ces deux variables vides désactive la fonctionnalité (le bouton
# renverra une erreur explicite) — aucun impact sur le reste de l'application.
#   Exemple : SSH_HOST=192.0.2.10 / SSH_USER=deploy
# -----------------------------------------------------------------------------
#SSH_HOST=
#SSH_USER=

# Chemin de la clé privée Ed25519 utilisée pour cette connexion SSH, à
# l'intérieur du conteneur backend (défaut si absent : /home/appuser/.ssh/id_ed25519).
#SSH_KEY_PATH=/home/appuser/.ssh/id_ed25519

# Port SSH de la machine hôte cible (défaut si absent : 22).
#SSH_PORT=22

# -----------------------------------------------------------------------------
# Webhooks entrants (GitHub Security Advisories, alertes KEV)
#
# Secret HMAC-SHA256 vérifiant la signature `X-Hub-Signature-256` des requêtes
# reçues sur /webhooks/github et /webhooks/kev. OBLIGATOIRE en production —
# sans lui, n'importe qui connaissant l'URL peut injecter de fausses alertes.
#   Générer avec : openssl rand -hex 32
# -----------------------------------------------------------------------------
WEBHOOK_SECRET=CHANGE_ME_GENERATE_A_RANDOM_64_HEX_STRING

# Bypass de la vérification de signature — DEV/TEST UNIQUEMENT. Ne jamais
# activer en production : n'importe qui pourrait alors injecter de fausses
# alertes de sécurité sans connaître WEBHOOK_SECRET.
#WEBHOOK_SIGNATURE_SKIP=false

# -----------------------------------------------------------------------------
# Prometheus — jeton Bearer optionnel protégeant GET /metrics
# Laisser vide/absent : /metrics reste accessible sans authentification.
#   Exemple : openssl rand -hex 32
# -----------------------------------------------------------------------------
#METRICS_TOKEN=

# -----------------------------------------------------------------------------
# Divers — réglages optionnels rarement modifiés
# -----------------------------------------------------------------------------
# Durée de vie (secondes) du cache mémoire des métadonnées .deb/.rpm/.apk
# (services/manifest.py) — défaut : 30.
#MANIFEST_CACHE_TTL=30

# Journalise chaque requête SQL exécutée par SQLAlchemy — DEBUG UNIQUEMENT,
# très verbeux, ne jamais activer en production.
#SQL_ECHO=false

# Répertoire des modèles d'e-mail (page "Templates") et des jetons de
# réinitialisation de mot de passe — défauts /repos/templates/email et
# /repos/auth respectivement. ⚠ Aucun des deux n'a de volume Docker dédié
# dans docker-compose.yaml : sur un déploiement par défaut, leur contenu ne
# survit PAS à une recréation du conteneur backend (les modèles personnalisés
# repartent aux valeurs par défaut, les jetons de réinitialisation en cours
# sont invalidés). Ajoutez vos propres bind mounts si la persistance de l'un
# ou l'autre vous importe.
#EMAIL_TEMPLATES_DIR=/repos/templates/email
#AUTH_DIR=/repos/auth

# reprepro (APT uniquement) — liste des distributions par défaut pour
# `remove_package()` quand aucune distribution explicite n'est passée
# (défaut : "jammy,noble,focal,bookworm", doit rester cohérent avec
# services/distributions_apt.py:VALID_CODENAMES si vous l'aviez modifié).
# REPREPRO_CONTAINER n'est utilisé que si vous appelez remove_package() avec
# via_docker=True (mode dev avec docker.sock monté, ex. docker-compose.dev.yml) —
# sans effet dans le déploiement de production par défaut.
#REPREPRO_DISTS=jammy,noble,focal,bookworm
#REPREPRO_CONTAINER=depot-apt
